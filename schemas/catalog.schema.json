{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schemaVersion", "marketplaceId", "name", "plugins"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "marketplaceId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "plugins": { "type": "array", "items": { "$ref": "#/$defs/plugin" }, "uniqueItems": true }
  },
  "$defs": {
    "plugin": {
      "type": "object",
      "required": ["id", "name", "version", "repository", "ref", "refType", "resolvedCommit", "manifestPath", "trustLevel", "permissions", "capabilities"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$" },
        "repository": { "type": "string", "pattern": "^https://" },
        "ref": { "type": "string" },
        "refType": { "enum": ["branch", "tag", "commit"] },
        "resolvedCommit": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
        "manifestPath": { "type": "string", "pattern": "^[^./][^\\r\\n]*$" },
        "trustLevel": { "const": "sandboxed" },
        "hostVersionRange": { "type": "string", "minLength": 1 },
        "permissions": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "capabilities": { "type": "array", "items": { "$ref": "#/$defs/capability" }, "uniqueItems": true }
      }
    },
    "capability": {
      "type": "object",
      "required": ["id", "kind", "operations"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
        "kind": { "enum": ["media-source", "metadata-provider", "transformer", "importer"] },
        "operations": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
        "match": { "type": "object", "additionalProperties": false, "properties": {
          "hosts": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "schemes": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "mimeTypes": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
        } }
      }
    }
  }
}
